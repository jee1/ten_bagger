{
  "name": "ten_bagger",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:daily": "cd scripts && python generate_daily.py",
    "test:python": "cd scripts && python -m pytest tests/ -q",
    "validate:content": "cd scripts && python sync_manifest.py && python validate_content.py",
    "gen:types": "node scripts/gen_types.mjs",
    "gen:types:check": "node scripts/gen_types.mjs --check",
    "check": "npm run gen:types:check && astro check"
  },
  "dependencies": {
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/node": "^26.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^6.0.3"
  }
}
