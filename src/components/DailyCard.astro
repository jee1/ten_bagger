---
import { label, shortText, t } from '../lib/i18n';
import type { Lang } from '../lib/i18n';
import type { DailyEntry } from '../lib/types';

interface Props {
  entry: DailyEntry;
  lang: Lang;
  detail?: boolean;
}

const { entry, lang, detail = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const marketLabel = entry.market === 'KR' ? label('marketKR', lang) : label('marketUS', lang);
const profile = entry.stock?.profile;
const profileOverview = profile ? t(profile.overview, lang) : '';
const displayOverview = profileOverview
  ? detail
    ? profileOverview
    : shortText(profileOverview)
  : '';
---

<article class="card">
  <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.75rem;">
    <span class="badge">{entry.date}</span>
    <span class={`badge ${entry.market === 'KR' ? 'kr' : 'us'}`}>{marketLabel}</span>
    <span class={`badge ${entry.status === 'pick' ? 'pick' : 'none'}`}>
      {entry.status === 'pick' ? label('pick', lang) : label('none', lang)}
    </span>
  </div>

  {entry.status === 'no_pick' ? (
    <>
      <h1>{label('noPickTitle', lang)}</h1>
      <p class="muted">{label('noPickBody', lang)}</p>
      {entry.scores && (
        <p class="muted">
          {lang === 'ko' ? '임계 점수' : 'Threshold'}: {entry.scores.threshold}
          {entry.meta && ` · ${lang === 'ko' ? '스크리닝' : 'Screened'}: ${entry.meta.candidatesScreened}`}
        </p>
      )}
    </>
  ) : entry.stock && entry.reasoning && entry.scores ? (
    <>
      <h1>{entry.stock.symbol}</h1>
      <p class="muted">{t(entry.stock.name, lang)} · {entry.stock.exchange}</p>
      {profile && displayOverview && (
        <section class="profile-section">
          <h2 class="section-title">{label('companyProfile', lang)}</h2>
          <p>{displayOverview}</p>
          {detail && (profile.sector || profile.industry) && (
            <p class="muted profile-meta">
              {profile.sector && (
                <span>{label('sector', lang)}: {t(profile.sector, lang)}</span>
              )}
              {profile.sector && profile.industry && <span> · </span>}
              {profile.industry && (
                <span>{label('industry', lang)}: {t(profile.industry, lang)}</span>
              )}
            </p>
          )}
        </section>
      )}
      <p>{t(entry.reasoning.summary, lang)}</p>

      <div class="score-grid">
        <div class="score-item">
          <div class="value">{entry.scores.composite.toFixed(1)}</div>
          <div class="label">{label('composite', lang)}</div>
        </div>
        {entry.scores.size != null && (
          <div class="score-item">
            <div class="value">{entry.scores.size.toFixed(1)}</div>
            <div class="label">{label('size', lang)}</div>
          </div>
        )}
        <div class="score-item">
          <div class="value">{entry.scores.growth.toFixed(1)}</div>
          <div class="label">{label('growth', lang)}</div>
        </div>
        <div class="score-item">
          <div class="value">{entry.scores.valuation.toFixed(1)}</div>
          <div class="label">{label('valuation', lang)}</div>
        </div>
        {entry.scores.entry != null && (
          <div class="score-item">
            <div class="value">{entry.scores.entry.toFixed(1)}</div>
            <div class="label">{label('entry', lang)}</div>
          </div>
        )}
        <div class="score-item">
          <div class="value">{entry.scores.momentum.toFixed(1)}</div>
          <div class="label">{label('momentum', lang)}</div>
        </div>
        <div class="score-item">
          <div class="value">{entry.scores.quality.toFixed(1)}</div>
          <div class="label">{label('quality', lang)}</div>
        </div>
      </div>

      {detail ? (
        <>
          {entry.reasoning.size && (
            <>
              <h2 class="section-title">{label('size', lang)}</h2>
              <p>{t(entry.reasoning.size, lang)}</p>
            </>
          )}
          <h2 class="section-title">{label('growth', lang)}</h2>
          <p>{t(entry.reasoning.growth, lang)}</p>
          <h2 class="section-title">{label('valuation', lang)}</h2>
          <p>{t(entry.reasoning.valuation, lang)}</p>
          {entry.reasoning.entry && (
            <>
              <h2 class="section-title">{label('entry', lang)}</h2>
              <p>{t(entry.reasoning.entry, lang)}</p>
            </>
          )}
          <h2 class="section-title">{label('momentum', lang)}</h2>
          <p>{t(entry.reasoning.momentum, lang)}</p>
          {entry.reasoning.quality && (
            <>
              <h2 class="section-title">{label('quality', lang)}</h2>
              <p>{t(entry.reasoning.quality, lang)}</p>
            </>
          )}
          <h2 class="section-title">{label('risks', lang)}</h2>
          <ul class="risk-list">
            {entry.reasoning.risks.map((risk) => (
              <li>{t(risk, lang)}</li>
            ))}
          </ul>
        </>
      ) : (
        <p><a href={`${base}daily/${entry.date}?lang=${lang}`}>{label('viewDetail', lang)} →</a></p>
      )}
    </>
  ) : null}
</article>
