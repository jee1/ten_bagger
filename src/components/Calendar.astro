---
import { label } from '../lib/i18n';
import type { Lang } from '../lib/i18n';
import type { DailyEntry } from '../lib/types';

interface Props {
  year: number;
  month: number;
  entries: Map<string, DailyEntry>;
  lang: Lang;
}

const { year, month, entries, lang } = Astro.props;
const base = import.meta.env.BASE_URL;

const firstDay = new Date(year, month - 1, 1);
const startWeekday = firstDay.getDay();
const daysInMonth = new Date(year, month, 0).getDate();

const prev = month === 1 ? { y: year - 1, m: 12 } : { y: year, m: month - 1 };
const next = month === 12 ? { y: year + 1, m: 1 } : { y: year, m: month + 1 };

const weekdays =
  lang === 'ko'
    ? ['일', '월', '화', '수', '목', '금', '토']
    : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
---

<div class="calendar-nav">
  <a href={`${base}archive?year=${prev.y}&month=${prev.m}&lang=${lang}`}>← {label('prevMonth', lang)}</a>
  <strong>{year}-{String(month).padStart(2, '0')}</strong>
  <a href={`${base}archive?year=${next.y}&month=${next.m}&lang=${lang}`}>{label('nextMonth', lang)} →</a>
</div>

<table class="calendar" aria-label={label('archive', lang)}>
  <thead>
    <tr>
      {weekdays.map((d) => <th>{d}</th>)}
    </tr>
  </thead>
  <tbody>
    {
      (() => {
        const rows: unknown[] = [];
        let cells: unknown[] = [];
        for (let i = 0; i < startWeekday; i++) {
          cells.push(<td class="empty" />);
        }
        for (let day = 1; day <= daysInMonth; day++) {
          const date = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
          const entry = entries.get(date);
          if (entry) {
            if (entry.status === 'pick') {
              cells.push(
                <td class="has-pick">
                  <a href={`${base}daily/${date}?lang=${lang}`}>{day}</a>
                  <div class="muted" style="font-size:0.7rem">{entry.stock?.symbol}</div>
                </td>,
              );
            } else {
              cells.push(
                <td class="no-pick">
                  {day}
                  <div>{label('none', lang)}</div>
                </td>,
              );
            }
          } else {
            cells.push(<td class="empty">{day}</td>);
          }
          if (cells.length === 7) {
            rows.push(<tr>{cells}</tr>);
            cells = [];
          }
        }
        if (cells.length > 0) {
          while (cells.length < 7) cells.push(<td class="empty" />);
          rows.push(<tr>{cells}</tr>);
        }
        return rows;
      })()
    }
  </tbody>
</table>
