---
import Layout from '../../layouts/Layout.astro';
import DailyCard from '../../components/DailyCard.astro';
import { getAllDates, getDailyEntry } from '../../lib/daily';
import { label } from '../../lib/i18n';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return getAllDates().map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const lang = (Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'ko') as Lang;
const entry = await getDailyEntry(date!);

if (!entry) {
  return Astro.redirect(`${import.meta.env.BASE_URL}archive?lang=${lang}`);
}
---

<Layout title={date!} lang={lang}>
  <p><a href={`${import.meta.env.BASE_URL}archive?lang=${lang}`}>← {label('archive', lang)}</a></p>
  <DailyCard entry={entry} lang={lang} detail />
</Layout>
