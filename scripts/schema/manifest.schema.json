{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manifest",
  "type": "object",
  "required": ["dates", "lastUpdated"],
  "additionalProperties": false,
  "properties": {
    "dates": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
    },
    "lastUpdated": { "type": "string" }
  }
}
