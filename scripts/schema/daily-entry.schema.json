{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DailyEntry",
  "type": "object",
  "required": ["date", "market", "status"],
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "market": { "enum": ["KR", "US"] },
    "status": { "enum": ["pick", "no_pick"] },
    "stock": {
      "type": "object",
      "required": ["symbol", "name", "exchange", "currency"],
      "properties": {
        "symbol": { "type": "string" },
        "name": { "$ref": "#/$defs/localizedText" },
        "exchange": { "type": "string" },
        "currency": { "enum": ["KRW", "USD"] }
      }
    },
    "scores": {
      "type": "object",
      "required": ["composite", "growth", "valuation", "momentum", "quality", "threshold"],
      "properties": {
        "composite": { "type": "number" },
        "growth": { "type": "number" },
        "valuation": { "type": "number" },
        "momentum": { "type": "number" },
        "quality": { "type": "number" },
        "threshold": { "type": "number" }
      }
    },
    "reasoning": {
      "type": "object",
      "properties": {
        "summary": { "$ref": "#/$defs/localizedText" },
        "growth": { "$ref": "#/$defs/localizedText" },
        "valuation": { "$ref": "#/$defs/localizedText" },
        "momentum": { "$ref": "#/$defs/localizedText" },
        "quality": { "$ref": "#/$defs/localizedText" },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["generatedAt", "candidatesScreened", "excludedRecent"],
      "properties": {
        "generatedAt": { "type": "string" },
        "candidatesScreened": { "type": "integer", "minimum": 0 },
        "excludedRecent": { "type": "integer", "minimum": 0 },
        "skippedMarketCap": { "type": "integer", "minimum": 0 },
        "noData": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "pick" } } },
      "then": { "required": ["stock", "scores", "reasoning", "meta"] }
    },
    {
      "if": { "properties": { "status": { "const": "no_pick" } } },
      "then": { "required": ["scores", "meta"] }
    }
  ],
  "$defs": {
    "localizedText": {
      "title": "LocalizedText",
      "type": "object",
      "required": ["ko", "en"],
      "additionalProperties": false,
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      }
    }
  }
}
